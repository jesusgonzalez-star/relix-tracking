# =============================================================================
# Variables de entorno para PRODUCCION (Linux / Debian)
# Copiar a /etc/tracking-app/env y completar valores reales.
# NUNCA subir este archivo con credenciales a git (ya esta en .gitignore).
# =============================================================================

# --- App Core ---
DEBUG=False
FLASK_ENV=production
# Genere cada secreto con: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Longitud minima 32 caracteres. La app no arranca con placeholders en prod.
SECRET_KEY=REEMPLAZAR_POR_TOKEN_URLSAFE_48
API_SECRET=REEMPLAZAR_POR_TOKEN_URLSAFE_48
# Opcional: secreto antiguo aceptado temporalmente durante rotacion (vacio = desactivado).
# API_SECRET_OLD=

# --- Base local MariaDB/MySQL (tracking + usuarios) ---
# REQUERIDO: la app no arranca sin este URI.
SQLALCHEMY_DATABASE_URI=mysql+pymysql://tracking_app:REEMPLAZAR@127.0.0.1:3306/tracking?charset=utf8mb4
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_CONNECT_TIMEOUT=10
SQLALCHEMY_ECHO=False
# Exige autenticacion SQL en vez de Trusted Connection (recomendado en Linux).
LOCAL_DB_REQUIRE_SQL_AUTH=True
LOCAL_DB_USER=tracking_app
LOCAL_DB_PASS=REEMPLAZAR

# --- ERP Softland (SQL Server, solo lectura) ---
DB_SERVER=192.168.x.x
DB_NAME=ZDESARROLLO
DB_USER=tracking_reader
DB_PASS=REEMPLAZAR
DB_DRIVER=ODBC Driver 18 for SQL Server
SOFTLAND_TIMEOUT=15
SOFTLAND_OC_CACHE_TTL=300
# Driver 18: TLS. En LAN interna sin CA corporativa: Encrypt=no, TrustServerCertificate=yes.
SOFTLAND_ENCRYPT=no
SOFTLAND_TRUST_CERT=yes

# --- Almacenamiento de evidencias ---
EVIDENCE_UPLOAD_DIR=/var/data/tracking/evidencias
MAX_CONTENT_LENGTH=16777216

# --- Sesion y cookies ---
# Secure=True exige HTTPS. Requiere Apache/Nginx con SSL delante (BEHIND_PROXY=True).
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=1800
SESSION_REFRESH_EACH_REQUEST=True

# --- CSRF y rate limiting ---
CSRF_ENABLED=True
LOGIN_RATE_LIMIT_ENABLED=True
RATELIMIT_ENABLED=True
RATELIMIT_API=60 per minute
RATELIMIT_LOGIN=10 per minute
# Con varios workers (gunicorn WORKERS>1) use redis para contadores coordinados.
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379

# --- Reverse proxy (activar si Apache/Nginx termina TLS delante) ---
BEHIND_PROXY=True

# --- Host Header protection (Host: rechazado si no coincide) ---
# Lista separada por comas. Opcional pero recomendado en prod.
ALLOWED_HOSTS=tracking.relix.local,tracking.relix.cl

# --- CORS ---
# Lista explicita. NUNCA usar "*" (la app lo rechaza con credentials=True).
CORS_ALLOWED_ORIGINS=https://tracking.relix.local

# --- Swagger / diagnosticos ---
ENABLE_SWAGGER=False
HIDE_DEMO_CREDENTIALS=True

# --- Validaciones de negocio ---
TRACKING_VALIDATE_OC_IN_SOFTLAND=True

# --- Gunicorn ---
PORT=5000
WORKERS=4
LOG_LEVEL=info
TIMEOUT=180
GRACEFUL_TIMEOUT=30
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100
# GUNICORN_BIND=127.0.0.1:5000
# GUNICORN_PID_FILE=/run/tracking-app/gunicorn.pid

# --- SSL directo (solo si NO hay Apache/Nginx terminando TLS) ---
# SSL_KEYFILE=/etc/ssl/private/tracking.key
# SSL_CERTFILE=/etc/ssl/certs/tracking.crt
