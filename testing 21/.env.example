# Copie a .env y complete valores reales (no subir .env al repositorio).

SECRET_KEY=cambiar-por-clave-larga-y-aleatoria
DEBUG=False

# Obligatorio si DEBUG=False: protege /api/softland y /api/tracking (Bearer o X-API-Key).
# En DEBUG=True sin API_SECRET esas rutas siguen abiertas (solo desarrollo/demos Windows).
API_SECRET=cambiar-por-token-largo-aleatorio

# Sesión: poner True detrás de HTTPS en producción
SESSION_COOKIE_SECURE=False

# Documentación API (Flasgger). En producción suele usarse False
ENABLE_SWAGGER=False

# Puerto al ejecutar python app.py
PORT=5000

# Base local SQLAlchemy (ajustar servidor y base)
# LOCAL_SERVER=...
# LOCAL_DB_NAME=...

# Softland (solo lectura). Si las define aquí, sustituyen a los valores por defecto de config.py.
# DB_SERVER=...
# DB_NAME=...
# DB_USER=...
# DB_PASS=...
# DB_DRIVER=ODBC Driver 17 for SQL Server

# Evidencias (opcional)
# EVIDENCE_UPLOAD_DIR=...
# MAX_CONTENT_LENGTH=16777216

# Rate limit por IP en /api/softland y /api/tracking (desactivar con False; en varios workers use Redis en storage de limiter)
# RATELIMIT_ENABLED=True
# RATELIMIT_API=60 per minute

# Exige que la OC exista en Softland al hacer POST /api/tracking (default False)
# TRACKING_VALIDATE_OC_IN_SOFTLAND=False
