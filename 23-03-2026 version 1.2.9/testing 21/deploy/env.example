# =============================================================================
# Variables de entorno para produccion Linux
# Copiar a /etc/tracking-app/env y completar valores reales.
# NUNCA subir este archivo con credenciales a git.
# =============================================================================

# --- App Core ---
DEBUG=False
SECRET_KEY=CAMBIAR-generar-con-python3-c-import-secrets-secrets.token_urlsafe(48)
API_SECRET=CAMBIAR-generar-con-python3-c-import-secrets-secrets.token_urlsafe(48)

# --- Base de datos Softland ERP (solo lectura) ---
DB_SERVER=192.168.x.x
DB_NAME=ZDESARROLLO
DB_USER=tracking_reader
DB_PASS=CAMBIAR
DB_DRIVER=ODBC Driver 17 for SQL Server

# --- Base de datos local (tracking / usuarios) ---
LOCAL_SERVER=192.168.x.x
LOCAL_DB_NAME=Softland_Mock
LOCAL_DB_USER=tracking_app
LOCAL_DB_PASS=CAMBIAR
LOCAL_DB_DRIVER=ODBC Driver 17 for SQL Server
LOCAL_DB_REQUIRE_SQL_AUTH=True

# --- Almacenamiento de evidencias ---
EVIDENCE_UPLOAD_DIR=/var/data/tracking/evidencias

# --- Sesion y seguridad ---
SESSION_COOKIE_SECURE=True
CSRF_ENABLED=True
LOGIN_RATE_LIMIT_ENABLED=True
RATELIMIT_ENABLED=True
RATELIMIT_API=60 per minute
RATELIMIT_LOGIN=10 per minute

# --- Rate limiter storage (memory:// para 1 worker, redis:// para multi-worker) ---
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# --- Reverse proxy (activar si Apache/Nginx esta delante) ---
BEHIND_PROXY=True

# --- Gunicorn ---
PORT=5000
WORKERS=4
LOG_LEVEL=info
# GUNICORN_BIND=127.0.0.1:5000

# --- Swagger (desactivar en produccion) ---
ENABLE_SWAGGER=False
HIDE_DEMO_CREDENTIALS=True
