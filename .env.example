# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN PARA PRODUCCIÓN EN DEBIAN + APACHE + MARIADB
# ═══════════════════════════════════════════════════════════════════════════════

# ── Flask Core ──
DEBUG=False
FLASK_ENV=production
SECRET_KEY=tu-clave-aleatoria-de-32-bytes-aqui
API_SECRET=tu-api-secret-aqui

# ── Port & Binding ──
PORT=5000
GUNICORN_BIND=127.0.0.1:5000

# ── Database: Softland ERP (SQL Server - Solo Lectura) ──
DB_SERVER=RELIX-SQL01\SOFTLAND
DB_NAME=ZDESARROLLO02
DB_USER=JGonzalez
DB_PASS=tu-contraseña-aqui
DB_DRIVER=ODBC Driver 17 for SQL Server
SOFTLAND_TIMEOUT=15
SOFTLAND_OC_CACHE_TTL=300

# ── Database: Local Tracking (MariaDB/MySQL en Debian) ──
# URI format: mysql+pymysql://user:password@host:port/database?charset=utf8mb4
SQLALCHEMY_DATABASE_URI=mysql+pymysql://tracking_user:tracking_pass@localhost:3306/tracking_db?charset=utf8mb4

# Connection Pool tuning (MariaDB)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_CONNECT_TIMEOUT=10

# ── Seguridad & Cookies ──
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ── CORS (cambiar a tu dominio real) ──
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ── Rate Limiting ──
RATELIMIT_ENABLED=True
RATELIMIT_API=60 per minute
LOGIN_RATE_LIMIT_ENABLED=True
RATELIMIT_LOGIN=10 per minute
RATELIMIT_STORAGE_URI=memory://

# ── Apache Reverse Proxy ──
BEHIND_PROXY=True
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# ── Gunicorn (systemd) ──
WORKERS=4
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100
TIMEOUT=180
GRACEFUL_TIMEOUT=30
GUNICORN_PID_FILE=/var/run/tracking-app.pid
GUNICORN_ACCESS_LOG=-
GUNICORN_ERROR_LOG=-
LOG_LEVEL=info

# ── Storage & Uploads ──
EVIDENCE_UPLOAD_DIR=/opt/tracking-app/storage/evidencias
MAX_CONTENT_LENGTH=16777216

# ── Features ──
CSRF_ENABLED=True
HIDE_DEMO_CREDENTIALS=True
TRACKING_VALIDATE_OC_IN_SOFTLAND=True
ENABLE_SWAGGER=False

# ── Logging ──
SQLALCHEMY_ECHO=False
